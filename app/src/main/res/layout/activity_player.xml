<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/skinBg"
    android:padding="10dp">

    <!-- Download status strip (visible while downloading; tap to open GET SONGS) -->
    <LinearLayout
        android:id="@+id/dlStrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/lcd_sunken"
        android:layout_marginTop="6dp"
        android:padding="7dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/dlText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="DL: …"
            android:textColor="?attr/skinLcd"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <ProgressBar
            android:id="@+id/dlBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progressTint="?attr/skinAccent"
            android:progressBackgroundTint="?attr/skinBevelLight" />
    </LinearLayout>

    <!-- Main deck (fixed) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bevel_raised"
        android:layout_marginTop="8dp"
        android:padding="10dp">

        <!-- Time LCD + spectrum -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/lcd_sunken"
                android:gravity="center"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="0:00"
                android:textColor="?attr/skinLcd"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <com.dgabesilva.ripmp3.SpectrumView
                android:id="@+id/spectrum"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/lcd_sunken" />
        </LinearLayout>

        <!-- Marquee track title -->
        <TextView
            android:id="@+id/marquee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/lcd_sunken"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:text="RIP // MP3 — WINAMP DECK"
            android:textColor="?attr/skinLcd"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <!-- kbps / kHz / channels readouts + menu button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@+id/kbpsText" style="@style/WaLcdChip" android:text="--- kbps" />
            <TextView android:id="@+id/khzText" style="@style/WaLcdChip" android:layout_marginStart="6dp" android:text="-- kHz" />
            <TextView android:id="@+id/chanText" style="@style/WaLcdChip" android:layout_marginStart="6dp" android:text="------" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/menuBtn"
                android:layout_width="40dp"
                android:layout_height="26dp"
                android:background="@drawable/wa_button"
                android:gravity="center"
                android:text="≡"
                android:textColor="?attr/skinAccent"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Position bar -->
        <SeekBar
            android:id="@+id/posBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:progressTint="?attr/skinLcd"
            android:progressBackgroundTint="?attr/skinBevelLight"
            android:thumbTint="?attr/skinAccent" />

        <!-- Transport -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView android:id="@+id/btnPrev" style="@style/WaBtn" android:text="⏮" />
            <TextView android:id="@+id/btnPlay" style="@style/WaBtn" android:text="▶" />
            <TextView android:id="@+id/btnPause" style="@style/WaBtn" android:text="⏸" />
            <TextView android:id="@+id/btnStop" style="@style/WaBtn" android:text="⏹" />
            <TextView android:id="@+id/btnNext" style="@style/WaBtn" android:text="⏭" />
            <TextView android:id="@+id/btnEject" style="@style/WaBtn" android:layout_marginEnd="0dp" android:text="⏏" />
        </LinearLayout>

        <!-- Shuffle / repeat / volume -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnShuffle"
                style="@style/WaChip"
                android:text="SHUF" />

            <TextView
                android:id="@+id/btnRepeat"
                style="@style/WaChip"
                android:layout_marginStart="6dp"
                android:text="REP" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="VOL"
                android:textColor="?attr/skinText"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <SeekBar
                android:id="@+id/volBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="80"
                android:progressTint="?attr/skinLcd"
                android:progressBackgroundTint="?attr/skinBevelLight"
                android:thumbTint="?attr/skinAccent" />
        </LinearLayout>
    </LinearLayout>

    <!-- Playlist editor: fills the rest of the screen, list scrolls inside -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bevel_raised"
        android:layout_marginTop="8dp"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYLIST:"
                android:textColor="?attr/skinAccent"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.18" />

            <TextView
                android:id="@+id/plName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="LIBRARY"
                android:textColor="?attr/skinLcd"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/plCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 trk"
                android:textColor="?attr/skinText"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <include layout="@layout/queue_header" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlistView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/lcd_sunken"
            android:padding="4dp" />
    </LinearLayout>
</LinearLayout>

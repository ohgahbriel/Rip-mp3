<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/skinBg"
    android:padding="10dp">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bevel_raised"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="6dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="◢ RIP // MP3 — GET SONGS"
            android:textColor="?attr/skinAccent"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.18" />

        <TextView
            android:id="@+id/backBtn"
            android:layout_width="30dp"
            android:layout_height="26dp"
            android:background="@drawable/wa_button"
            android:gravity="center"
            android:text="✕"
            android:textColor="?attr/skinText"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- URL entry panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bevel_raised"
        android:layout_marginTop="8dp"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUTUBE URL (VIDEO OR PLAYLIST)"
            android:textColor="?attr/skinText"
            android:textSize="10sp"
            android:letterSpacing="0.15" />

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/lcd_sunken"
            android:padding="10dp"
            android:hint="https://www.youtube.com/watch?v=…"
            android:textColor="?attr/skinLcd"
            android:textColorHint="?attr/skinBevelLight"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:inputType="textUri"
            android:maxLines="2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="FORMAT / QUALITY"
            android:textColor="?attr/skinText"
            android:textSize="10sp"
            android:letterSpacing="0.15" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView android:id="@+id/chipBest" style="@style/WaChip" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:text="BEST" />
            <TextView android:id="@+id/chip320" style="@style/WaChip" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:text="320K" />
            <TextView android:id="@+id/chip192" style="@style/WaChip" android:layout_width="0dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:text="192K" />
            <TextView android:id="@+id/chipFlac" style="@style/WaChip" android:layout_width="0dp" android:layout_weight="1" android:text="FLAC" />
        </LinearLayout>

        <TextView
            android:id="@+id/downloadBtn"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/wa_button"
            android:gravity="center"
            android:text="⇩ DOWNLOAD"
            android:textColor="?attr/skinAccent"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.15" />
    </LinearLayout>

    <!-- Status panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bevel_raised"
        android:layout_marginTop="8dp"
        android:padding="10dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/lcd_sunken"
            android:padding="8dp"
            android:text="Initializing yt-dlp…"
            android:textColor="?attr/skinLcd"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progressTint="?attr/skinLcd"
            android:progressBackgroundTint="?attr/skinBevelLight"
            android:visibility="gone" />

        <TextView
            android:id="@+id/cancelBtn"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/wa_button"
            android:gravity="center"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:text="⏹ CANCEL"
            android:textColor="@color/err"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="DOWNLOADS KEEP RUNNING IN THE BACKGROUND — GO BACK AND LISTEN WHILE THEY FINISH."
            android:textColor="?attr/skinText"
            android:textSize="9sp"
            android:letterSpacing="0.08"
            android:fontFamily="monospace" />
    </LinearLayout>

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Only download audio you have the rights to — your own uploads, Creative Commons content, or material with the owner's permission."
        android:textColor="?attr/skinBevelLight"
        android:textSize="10sp" />
</LinearLayout>

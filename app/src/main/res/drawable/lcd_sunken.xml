<?xml version="1.0" encoding="utf-8"?>
<!-- Sunken LCD display well: dark edge top-left, light edge bottom-right, near-black glass -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape><solid android:color="?attr/skinBevelDark" /></shape>
    </item>
    <item android:left="2dp" android:top="2dp">
        <shape><solid android:color="?attr/skinBevelLight" /></shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape><solid android:color="?attr/skinLcdBg" /></shape>
    </item>
</layer-list>

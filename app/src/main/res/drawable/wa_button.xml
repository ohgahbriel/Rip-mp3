<?xml version="1.0" encoding="utf-8"?>
<!-- Winamp transport button: raised bevel normally, sunken while pressed or toggled on -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item><shape><solid android:color="@color/waBevelDark" /></shape></item>
            <item android:left="2dp" android:top="2dp">
                <shape><solid android:color="@color/waBevelLight" /></shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape><solid android:color="@color/waPanelDeep" /></shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <layer-list>
            <item><shape><solid android:color="@color/waBevelDark" /></shape></item>
            <item android:left="2dp" android:top="2dp">
                <shape><solid android:color="@color/waBevelLight" /></shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape><solid android:color="@color/waPanelDeep" /></shape>
            </item>
        </layer-list>
    </item>
    <item android:drawable="@drawable/bevel_raised" />
</selector>

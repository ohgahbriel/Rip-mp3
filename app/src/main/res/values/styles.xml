<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg">#0D0D0D</color>
    <color name="panel">#161616</color>
    <color name="accent">#F5A200</color>
    <color name="text">#EDEDED</color>
    <color name="dim">#8A8A8A</color>
    <color name="err">#FF5C5C</color>

    <!-- Winamp deck palette -->
    <color name="waBg">#16161F</color>
    <color name="waPanel">#2B2B3B</color>
    <color name="waPanelDeep">#20202E</color>
    <color name="waBevelLight">#54546E</color>
    <color name="waBevelDark">#0A0A12</color>
    <color name="waLcdBg">#060609</color>
    <color name="waGreen">#00E800</color>
    <color name="waGreenDim">#0A6A0A</color>
    <color name="waGold">#E8C848</color>
    <color name="waText">#C8C8D8</color>

    <style name="Theme.RipMp3" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <style name="Label">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/dim</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <style name="Radio">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:buttonTint">@color/accent</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>

    <!-- Winamp transport button (TextView-based so the bevel drawable isn't tinted by Material) -->
    <style name="WaBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/wa_button</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/waText</item>
        <item name="android:textSize">17sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Small LCD info chip (kbps / kHz / channels) -->
    <style name="WaLcdChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/lcd_sunken</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">@color/waGreen</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>

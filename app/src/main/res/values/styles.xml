<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg">#0D0D0D</color>
    <color name="panel">#161616</color>
    <color name="accent">#F5A200</color>
    <color name="text">#EDEDED</color>
    <color name="dim">#8A8A8A</color>
    <color name="err">#FF5C5C</color>

    <style name="Theme.RipMp3" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <style name="Label">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/dim</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <style name="Radio">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:buttonTint">@color/accent</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>
</resources>

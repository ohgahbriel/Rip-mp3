<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="err">#FF5C5C</color>
    <color name="bg">#0D0D0D</color>
    <color name="accent">#F5A200</color>

    <!-- Skinnable Winamp palette: every screen styles itself through these attrs -->
    <attr name="skinBg" format="color" />         <!-- window background -->
    <attr name="skinPanel" format="color" />      <!-- raised chrome face -->
    <attr name="skinPanelDeep" format="color" />  <!-- pressed / selected face -->
    <attr name="skinBevelLight" format="color" />
    <attr name="skinBevelDark" format="color" />
    <attr name="skinLcdBg" format="color" />      <!-- LCD glass -->
    <attr name="skinLcd" format="color" />        <!-- LCD text -->
    <attr name="skinAccent" format="color" />     <!-- titles / highlights -->
    <attr name="skinText" format="color" />       <!-- chrome text -->

    <!-- SKIN 1: CLASSIC GREEN -->
    <style name="Theme.RipMp3" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">#16161F</item>
        <item name="android:navigationBarColor">#16161F</item>
        <item name="colorPrimary">#E8C848</item>
        <item name="skinBg">#16161F</item>
        <item name="skinPanel">#2B2B3B</item>
        <item name="skinPanelDeep">#20202E</item>
        <item name="skinBevelLight">#54546E</item>
        <item name="skinBevelDark">#0A0A12</item>
        <item name="skinLcdBg">#060609</item>
        <item name="skinLcd">#00E800</item>
        <item name="skinAccent">#E8C848</item>
        <item name="skinText">#C8C8D8</item>
    </style>

    <!-- SKIN 2: ICE BLUE -->
    <style name="Theme.RipMp3.Ice">
        <item name="android:statusBarColor">#0A1018</item>
        <item name="android:navigationBarColor">#0A1018</item>
        <item name="colorPrimary">#9AD6FF</item>
        <item name="skinBg">#0A1018</item>
        <item name="skinPanel">#1C2A3A</item>
        <item name="skinPanelDeep">#142030</item>
        <item name="skinBevelLight">#3E5A78</item>
        <item name="skinBevelDark">#05080D</item>
        <item name="skinLcdBg">#02060A</item>
        <item name="skinLcd">#00D8FF</item>
        <item name="skinAccent">#9AD6FF</item>
        <item name="skinText">#BCD4E8</item>
    </style>

    <!-- SKIN 3: HELLFIRE -->
    <style name="Theme.RipMp3.Hellfire">
        <item name="android:statusBarColor">#180A0A</item>
        <item name="android:navigationBarColor">#180A0A</item>
        <item name="colorPrimary">#FFA030</item>
        <item name="skinBg">#180A0A</item>
        <item name="skinPanel">#38201C</item>
        <item name="skinPanelDeep">#2A1512</item>
        <item name="skinBevelLight">#6E4038</item>
        <item name="skinBevelDark">#120505</item>
        <item name="skinLcdBg">#0A0303</item>
        <item name="skinLcd">#FF3A2A</item>
        <item name="skinAccent">#FFA030</item>
        <item name="skinText">#E0C0B4</item>
    </style>

    <!-- Winamp transport button (TextView-based so the bevel drawable isn't tinted by Material) -->
    <style name="WaBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:background">@drawable/wa_button</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">?attr/skinText</item>
        <item name="android:textSize">17sp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Small chrome toggle chip (SHUF / REP / format picker / browser tabs) -->
    <style name="WaChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:background">@drawable/wa_button</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">10dp</item>
        <item name="android:paddingRight">10dp</item>
        <item name="android:textColor">?attr/skinText</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Small LCD info chip (kbps / kHz / channels) -->
    <style name="WaLcdChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/lcd_sunken</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">?attr/skinLcd</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
